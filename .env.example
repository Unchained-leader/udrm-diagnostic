# ═══════════════════════════════════════════════════════════════
# Unchained Marketing Coach — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# Ask Mason for production values if you need them.
# ═══════════════════════════════════════════════════════════════

# ── Core App ──
NEXT_PUBLIC_APP_URL=https://unchainedleader.io
JWT_SECRET=your-secure-random-string-here

# ── AI / Claude ──
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database (Neon PostgreSQL) ──
DATABASE_URL=postgresql://user:pass@host/dbname
POSTGRES_URL=postgresql://user:pass@host/dbname
POSTGRES_URL_NON_POOLING=postgresql://user:pass@host-unpooled/dbname

# ── Cache / Session Store (Upstash Redis via Vercel KV) ──
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your-redis-token-here

# ── Queue (Upstash QStash) ──
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_your-current-key
QSTASH_NEXT_SIGNING_KEY=sig_your-next-key

# ── Email (Resend) ──
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=Unchained Leader <reports@unchainedleader.com>

# ── CRM (GoHighLevel) ──
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-webhook-url
GHL_REPORT_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-report-webhook-url

# ── Admin ──
ADMIN_PASSWORD=your-admin-password-here
ADMIN_KEY=your-admin-key-here

# ── Monitoring (Optional) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_EMAIL=team@unchainedleader.com
