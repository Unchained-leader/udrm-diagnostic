# ===== REQUIRED =====

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT secret for dashboard authentication (must be set in production)
JWT_SECRET=your-secure-random-string-here

# Upstash Redis (Vercel KV)
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your-redis-token-here

# Neon Postgres
DATABASE_URL=postgresql://user:pass@host/dbname

# ===== ADMIN =====

# Admin auth keys for debug endpoints
ADMIN_KEY=your-admin-key-here
ADMIN_PASSWORD=your-admin-password-here

# ===== OPTIONAL =====

# Email (Resend.com) — must be verified sender domains
ALERT_EMAIL=your-coaching-team@email.com
RESEND_API_KEY=re_your-key-here
RESEND_FROM_EMAIL=Unchained Leader <reports@yourdomain.com>
RESET_FROM_EMAIL=Unchained Support <support@yourdomain.com>

# Slack webhook for crisis alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# GoHighLevel CRM Webhooks
# Contact creation workflow
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-location/webhook-trigger/your-trigger-id
# Report delivery workflow (Reports | Root Diagnostic)
GHL_REPORT_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-location/webhook-trigger/your-trigger-id
