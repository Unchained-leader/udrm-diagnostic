# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Email alert for crisis detection (set up with Resend.com)
ALERT_EMAIL=your-coaching-team@email.com
RESEND_API_KEY=re_your-key-here

# Optional: Slack webhook for crisis alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# GoHighLevel CRM Webhooks
# Contact creation workflow (existing)
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-location/webhook-trigger/your-trigger-id
# Report delivery workflow (Reports | Root Diagnostic)
GHL_REPORT_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/your-location/webhook-trigger/your-trigger-id
